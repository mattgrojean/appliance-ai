# Local development environment variables for ai/app
# Copy this to .env and fill in your values, then:
#   cd ai/app && uvicorn main:app --reload

# AI Inference endpoint (from: terraform output inference_endpoint)
AZURE_INFERENCE_ENDPOINT=https://ais-techai-msdn-dev.services.ai.azure.com/models

# gpt-4o deployment name (as deployed in AI Foundry)
AZURE_AI_CHAT_DEPLOYMENT_NAME=gpt-4o

# Azure AI Search endpoint (from: terraform output search_endpoint)
AZURE_AI_SEARCH_ENDPOINT=https://srch-techai-msdn-dev.search.windows.net

# Index names (defaults — only change if you renamed them)
SEARCH_INDEX_TICKETS=repair-tickets
SEARCH_INDEX_MANUALS=service-manuals

# Entra tenant ID — used by AzureDeveloperCliCredential for local auth
AZURE_TENANT_ID=1ed2126d-597d-465e-b5df-95e96c61399f

# ── Production-only (set by Terraform / Container App env vars) ────────────
# AZURE_CLIENT_ID=<uami-client-id>       # from: terraform output chat_app_identity_client_id
# RUNNING_IN_PRODUCTION=true             # switches credential to ManagedIdentityCredential
# ENTRA_CLIENT_ID=<entra-app-client-id>  # for Easy Auth post-deploy config
